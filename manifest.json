{
    "manifest_version": 3,
    "name": "Kiroku",
    "version": "1.0",
    "description": "Convenient word lookups without having to leave your window. Default trigger key is 'Ctrl' or 'Cmd'",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "unlimitedStorage"],
    "host_permissions": ["http://127.0.0.1:8765/"],
    "content_scripts" : [
        {
            "matches": ["<all_urls>"],
            "js": ["src/vendor/browser-polyfill.js", "src/content/contentScript.js"],
            "css": ["src/styles/content.css"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["dict/data.noun",
            "dict/data.verb",
            "dict/data.adj", 
            "dict/data.adv", 
            "src/data/english.json"],
            "matches": ["<all_urls>"]
        }
    ],
    "background": {
        "service_worker": "src/background/background.js",
        "type": "module"
    },
    "icons": {
        "128": "popup/kirokulogo.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "popup/kirokulogo.png"
    },
    "options_page": "popup/options.html"
    
}