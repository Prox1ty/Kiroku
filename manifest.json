{
    "manifest_version": 3,
    "name": "Text Extractor on Key Press",
    "version": "1.0",
    "description": "Extract text content when 'Ctrl' key is pressed.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "unlimitedStorage"],
    "host_permissions": ["http://127.0.0.1:8765/"],
    "content_scripts" : [
        {
            "matches": ["<all_urls>"],
            "js": ["browser-polyfill.js", "scripts/contentScript.js"],
            "css": ["styles.css"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["dict/data.noun",
            "dict/data.verb",
            "dict/data.adj", 
            "dict/data.adv", 
            "english.json"],
            "matches": ["<all_urls>"]
        }
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "popup/popupicon.png"
    },
    "options_page": "popup/options.html"
    
}