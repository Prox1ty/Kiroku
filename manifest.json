{
    "manifest_version": 3,
    "name": "Text Extractor on Key Press",
    "version": "1.0",
    "description": "Extract text content when 'Ctrl' key is pressed.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "unlimitedStorage"],
    "content_scripts" : [
        {
            "matches": ["<all_urls>"],
            "js": ["browser-polyfill.js", "contentScript.js"],
            "css": ["styles.css"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["dict/data.noun",
            "dict/data.verb",
            "dict/data.adj", 
            "dict/data.adv", 
            "english.json"],
            "matches": ["<all_urls>"]
        }
    ],
    "background": {
        "service_worker": "background.js"
    }
    
}